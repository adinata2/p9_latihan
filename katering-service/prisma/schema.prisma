generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://mahasiswa:akucintafik@localhost:3306/fiteat_db"
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     String   @default("customer") // admin atau customer
  orders   Order[]
}

model Menu {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  calories    Int
  price       Int
  orders      Order[]
}

model Order {
  id         Int      @id @default(autoincrement())
  userId     Int
  menuId     Int
  status     String   @default("pending") // pending, processed
  created_at DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  menu Menu @relation(fields: [menuId], references: [id])
}